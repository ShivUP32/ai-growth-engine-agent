# Copy this file to .env.local for local development (vercel dev / vercel env pull).
# Never commit a real key. .env.local is already excluded in .gitignore.
# Walkthrough: docs/VERCEL_ENV_SETUP.md

# Groq API Key (Primary LLM)
# Get a key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key (Fallback LLM)
# Get a key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Jina AI API Key (Primary Search & Reader)
# Get a free key from: https://jina.ai/api-dashboard
JINA_API_KEY=jina_your_primary_api_key_here

# Jina AI API Key Fallback (Secondary Search & Reader)
JINA_API_KEY_FALLBACK=jina_your_fallback_api_key_here
